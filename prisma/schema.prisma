generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Comment {
  id        String   @id @default(cuid())
  postSlug  String
  author    String
  email     String
  body      String
  createdAt DateTime @default(now())

  @@index([postSlug])
}

enum ReactionType {
  like
}

model Reaction {
  id        String       @id @default(cuid())
  postSlug  String
  type      ReactionType
  sessionId String
  createdAt DateTime @default(now())

  @@unique([postSlug, type, sessionId])
  @@index([postSlug])
}

model View {
  postSlug  String   @id
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}
